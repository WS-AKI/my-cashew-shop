# Cloudflare ローカル開発用。本番は Cloudflare ダッシュボードまたは wrangler で設定。
NEXTJS_ENV=development
# wrangler deploy / preview 時に Worker へ渡す公開変数（日本向け）
NEXT_PUBLIC_AUDIENCE=ja
# お知らせ保存API用（本番は wrangler secret put ADMIN_PIN / SUPABASE_SERVICE_ROLE_KEY 推奨）
ADMIN_PIN=607051
# SUPABASE_SERVICE_ROLE_KEY=（ローカル wrangler でAPIを試す場合のみ。Supabase の service_role を貼る）
