# Supabase（必須）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LINE 通知（注文受付・スリップアップロード時に管理者へ Push）
# LINE Developers でチャネル作成後、Channel access token と 管理者の User ID を設定
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ── オーディエンス設定（必須）──────────────────────────────
# Cloudflare Pages 上で 2 つのプロジェクトを立ち上げ、それぞれに設定する。
#   日本向けプロジェクト（例: cashew-ja.pages.dev） → ja
#   タイ向けプロジェクト（例: cashew-th.pages.dev） → th
# 未設定の場合は th（タイ向け）になる。
NEXT_PUBLIC_AUDIENCE=th

# ── 任意 ─────────────────────────────────────────────────
# 各プロジェクトの本番 URL（sitemap.xml / OGP 等で使用）
# NEXT_PUBLIC_SITE_URL=https://cashew-th.pages.dev
# NEXT_PUBLIC_LINE_OFFICIAL_URL=https://line.me/R/ti/p/@xxx
# NEXT_PUBLIC_PROMPTPAY_ID=020457390910
