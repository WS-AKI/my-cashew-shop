# Supabase（必須）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 管理画面・お知らせAPI・VIP検証API 共通（サーバーのみ。クライアントに出さないこと）
# 注文管理のログインも /api/admin/ping でこの値と照合する（コードに PIN を書かない）
ADMIN_PIN=your-6-digit-or-secret-pin
# Supabase Dashboard → Settings → API → service_role（secret）
SUPABASE_SERVICE_ROLE_KEY=

# LINE 通知（注文受付・スリップアップロード時に管理者へ Push）
# LINE Developers でチャネル作成後、Channel access token と 管理者の User ID を設定
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ── オーディエンス設定（必須）──────────────────────────────
# 各デプロイで「ja」か「th」のどちらか一方だけを設定する（両方は入れない）。
#   ＜日本向けプロジェクト＞ NEXT_PUBLIC_AUDIENCE=ja
#   ＜タイ向けプロジェクト＞ NEXT_PUBLIC_AUDIENCE=th
# 未設定の場合は th（タイ向け）として扱う。
NEXT_PUBLIC_AUDIENCE=th

# ── 任意 ─────────────────────────────────────────────────
# 各プロジェクトの本番 URL（sitemap.xml / OGP / Magic Link 許可リストと揃える）
# Supabase Auth → URL に Site URL と Redirect URLs（例: https://ドメイン/auth/callback）を登録
# NEXT_PUBLIC_SITE_URL=https://cashew-th.pages.dev
# NEXT_PUBLIC_LINE_OFFICIAL_URL=https://line.me/R/ti/p/@xxx
# NEXT_PUBLIC_PROMPTPAY_ID=020457390910

# ── VIP 検証（ランク強制切替）開発ツール ─────────────────────
# 本番では未設定のまま（両方 false）。開発・ステージングでのみ true。
# ENABLE_ADMIN_LOYALTY_TEST_TOOLS … /api/admin/loyalty/test と test-users を有効化（必須）
# NEXT_PUBLIC_ENABLE_ADMIN_LOYALTY_TEST_TOOLS … /admin/vip のツール UI を表示（API と揃えること）
# ENABLE_ADMIN_LOYALTY_TEST_TOOLS=true
# NEXT_PUBLIC_ENABLE_ADMIN_LOYALTY_TEST_TOOLS=true
